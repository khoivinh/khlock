{
  "name": "happyhour-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create khlock-db",
    "db:migrate": "wrangler d1 execute khlock-db --file=migrations/0001_create_user_preferences.sql",
    "db:migrate:local": "wrangler d1 execute khlock-db --local --file=migrations/0001_create_user_preferences.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.77.0"
  },
  "dependencies": {
    "jose": "^5.9.6"
  }
}
